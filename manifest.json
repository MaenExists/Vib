{
  "manifest_version": 3,
  "name": "Vib",
  "version": "1.0.0",
  "description": "Premium keyboard navigation with glassmorphic UI, high-precision smooth scrolling, and intelligent auto-skip features.",
  "homepage_url": "https://github.com/MaenExists/Vib",
  "icons": {
    "128": "icon.svg"
  },
  "permissions": [
    "tabs",
    "history",
    "storage",
    "sessions",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*/*",
    "http://*/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      }
    },
    "open-vib-bar": {
      "suggested_key": {
        "default": "Ctrl+Space",
        "mac": "Command+Space"
      },
      "description": "Open Vib Command Bar"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "options_page": "options.html",
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "vib-extension@maen.builds",
      "strict_min_version": "109.0"
    }
  }
}
